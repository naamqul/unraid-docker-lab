# Reserve this address in ASUS DHCP before relying on it permanently.
CADDY_LAN_IP=192.168.50.52
CADDY_LAN_MAC=02:42:c0:a8:32:34

# Mutable Caddy state stays outside Git and docker.img.
CADDY_STATE_PATH=/mnt/user/appdata/caddy-state

# REQUIRED: enable API access for bonfireboogie.com in Porkbun, then copy the
# API credentials into the ignored .env file. Caddy uses these only for ACME
# DNS-01 challenges; no inbound Internet ports are required.
PORKBUN_API_KEY=UPDATE_ME
PORKBUN_API_SECRET_KEY=UPDATE_ME
