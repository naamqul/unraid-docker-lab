####################################
# Komodo bootstrap environment
####################################

# REQUIRED: replace every value containing UPDATE_ME before first startup.
# Mongo's initialization credentials are only applied to an empty database.

# Images and persistent Unraid storage
COMPOSE_KOMODO_IMAGE_TAG=2
KOMODO_STATE_PATH=/mnt/user/appdata/komodo-state
COMPOSE_KOMODO_BACKUPS_PATH=/mnt/user/appdata/komodo-state/backups

# REQUIRED: Mongo credentials
KOMODO_DATABASE_USERNAME=UPDATE_ME_DATABASE_USERNAME
KOMODO_DATABASE_PASSWORD=UPDATE_ME_DATABASE_PASSWORD

# Scheduling and links generated by Komodo
TZ=America/Los_Angeles
KOMODO_HOST=https://komodo.arc.home.arpa
KOMODO_TITLE=Komodo

# Core / Periphery key authentication
KOMODO_PERIPHERY_PUBLIC_KEY=file:/config/keys/periphery.pub
PERIPHERY_CORE_PUBLIC_KEYS=file:/config/keys/core.pub

# REQUIRED: initial local administrator
KOMODO_LOCAL_AUTH=true
KOMODO_MIN_PASSWORD_LENGTH=12
KOMODO_INIT_ADMIN_USERNAME=UPDATE_ME_ADMIN_USERNAME
KOMODO_INIT_ADMIN_PASSWORD=UPDATE_ME_ADMIN_PASSWORD

# Single-user / private-homelab defaults
KOMODO_DISABLE_USER_REGISTRATION=true
KOMODO_ENABLE_NEW_USERS=false
KOMODO_DISABLE_NON_ADMIN_CREATE=true
KOMODO_TRANSPARENT_MODE=false

# Create the local Unraid server and let Periphery connect outbound to Core.
KOMODO_FIRST_SERVER_NAME=Arc
PERIPHERY_CONNECT_AS=${KOMODO_FIRST_SERVER_NAME}
PERIPHERY_CORE_ADDRESS=ws://core:9120

# REQUIRED: use separate high-entropy values
KOMODO_WEBHOOK_SECRET=UPDATE_ME_WEBHOOK_SECRET
KOMODO_JWT_SECRET=UPDATE_ME_JWT_SECRET
KOMODO_JWT_TTL=1-day

# REQUIRED for authenticated `docker exec komodo km ...` commands. Generate
# this key pair for an appropriately privileged Komodo user. The Compose file
# maps these values to KOMODO_CLI_KEY and KOMODO_CLI_SECRET inside Core.
AGENT_API_KEY=UPDATE_ME_AGENT_API_KEY
AGENT_API_SECRET=UPDATE_ME_AGENT_API_SECRET

# Core behavior
KOMODO_DISABLE_CONFIRM_DIALOG=false
KOMODO_DISABLE_INIT_RESOURCES=false
KOMODO_MONITORING_INTERVAL=15-sec
KOMODO_RESOURCE_POLL_INTERVAL=1-hr
KOMODO_LOGGING_PRETTY=true
KOMODO_PRETTY_STARTUP_CONFIG=true

# Periphery filesystem. The path must be identical inside and outside
# the container; Compose bind-mounts it that way.
PERIPHERY_ROOT_DIRECTORY=/mnt/user/appdata/unraid-docker-lab/komodo
PERIPHERY_DISABLE_TERMINALS=false
PERIPHERY_DISABLE_CONTAINER_TERMINALS=false
PERIPHERY_INCLUDE_DISK_MOUNTS=/etc/hostname
PERIPHERY_LOGGING_PRETTY=false
PERIPHERY_PRETTY_STARTUP_CONFIG=false
